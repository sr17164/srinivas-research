---
import BaseLayout from '~/layouts/BaseLayout.astro'
import StandardLayout from '~/layouts/StandardLayout.astro'
import ListView from '~/components/views/ListView.astro'
import PageNavigation from '~/components/nav/PageNavigation.astro'
import Link from '~/components/base/Link.astro'
import { withBasePath } from '~/utils/path'
---

<BaseLayout
  title="Research"
  description="Independent research covering commodity markets, macroeconomic forces and global market structure."
  bgType="plum"
  ogImage="fallback"
>
  <StandardLayout>
    <section slot="article" class="research-index">
      <header class="research-index-header">
        <p class="research-index-eyebrow">SM Research</p>

        <h1>Research</h1>

        <p class="research-index-intro">
          Long-form research across commodity markets and macroeconomic forces,
          with explicit catalysts, risks, implementation frameworks and
          invalidation conditions.
        </p>

        <Link
          href={withBasePath('/outcomes/')}
          class="research-index-outcomes border-b-none!"
        >
          View the decision log
          <span aria-hidden="true">↗</span>
        </Link>

        <div class="research-index-rule"></div>
      </header>

      <ListView pageTag={false} />

      <PageNavigation current="research" />
    </section>
  </StandardLayout>
</BaseLayout>
