---
import { FEATURES } from '~/config'

interface Props {
  isArticle: boolean
}

const { isArticle } = Astro.props

const { toc } = FEATURES
if (!toc || (Array.isArray(toc) && !toc[0])) return
const { minHeadingLevel, maxHeadingLevel } = toc[1]
---

<table-of-contents
  data-min-h={isArticle ? minHeadingLevel : undefined}
  data-max-h={isArticle ? maxHeadingLevel : undefined}
  data-is-article={isArticle ? 'true' : 'false'}
  data-pagefind-ignore="all"
>
  <slot />
</table-of-contents>

<script>
  class Toc extends HTMLElement {
    #minH: number | undefined
    #maxH: number | undefined
    #observer: IntersectionObserver | null = null
    #headingMapToc = new Map<Element, HTMLAnchorElement[]>()
    #headings: Element[] = []
    #progressEls: HTMLElement[] = []
    #scrollFrame: number | null = null

    #currentActiveHeading: Element | null = null
    #previousActiveLinks: HTMLAnchorElement[] = []

    connectedCallback() {
      this.#onIdle(() => this.#init())
    }

    disconnectedCallback() {
      this.#cleanup()
    }

    #init = () => {
      this.#cleanup()

      this.#minH = this.#getHeadingLevel(this.dataset.minH)
      this.#maxH = this.#getHeadingLevel(this.dataset.maxH)

      const tocLinks = this.#getElements('a', false) as HTMLAnchorElement[]
      this.#generateHeadingMapToc(tocLinks)

      this.#headings =
        this.#minH && this.#maxH
          ? this.#getElements(
              this.#getTocHeadingsSelector(this.#minH, this.#maxH)
            )
          : this.#getElements('.toc-heading')

      this.#progressEls = this.#getElements(
        '[data-toc-progress]',
        false
      ) as HTMLElement[]

      this.#observer = new IntersectionObserver(this.#onIntersect, {
        root: null,
        rootMargin: '-15% 0% -70% 0%',
        threshold: 0,
      })

      for (const headingEl of this.#headings) {
        this.#observer.observe(headingEl)
      }

      window.addEventListener('scroll', this.#onScroll, { passive: true })
      window.addEventListener('resize', this.#onScroll, { passive: true })
      this.#updateProgress()

      const initialHeading = this.#getActiveHeadingFromScroll()
      if (initialHeading) this.#setActiveHeading(initialHeading, false)
    }

    #onIdle = (cb: IdleRequestCallback) =>
      (window.requestIdleCallback || ((cb) => setTimeout(cb, 1)))(cb)

    #onIntersect = () => {
      const targetHeading = this.#getActiveHeadingFromScroll()
      if (targetHeading) this.#setActiveHeading(targetHeading)
    }

    #onScroll = () => {
      if (this.#scrollFrame !== null) return

      this.#scrollFrame = window.requestAnimationFrame(() => {
        this.#scrollFrame = null
        this.#updateProgress()

        const targetHeading = this.#getActiveHeadingFromScroll()
        if (targetHeading) this.#setActiveHeading(targetHeading)
      })
    }

    #getActiveHeadingFromScroll = () => {
      if (!this.#headings.length) return null

      const activationLine = Math.max(96, window.innerHeight * 0.22)
      let activeHeading = this.#headings[0]

      for (const heading of this.#headings) {
        if (heading.getBoundingClientRect().top <= activationLine) {
          activeHeading = heading
        } else {
          break
        }
      }

      return activeHeading
    }

    #setActiveHeading = (targetHeading: Element, scrollIntoView = true) => {
      if (targetHeading === this.#currentActiveHeading) return

      const newLinks = this.#headingMapToc.get(targetHeading) ?? []

      for (const tocLinkEl of this.#previousActiveLinks) {
        tocLinkEl.removeAttribute('aria-current')
      }

      for (const tocLinkEl of newLinks) {
        tocLinkEl.setAttribute('aria-current', 'location')

        if (scrollIntoView && tocLinkEl.closest('#toc-sidebar')) {
          tocLinkEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' })
        }
      }

      this.#currentActiveHeading = targetHeading
      this.#previousActiveLinks = newLinks
    }

    #updateProgress = () => {
      if (!this.#progressEls.length || this.dataset.isArticle !== 'true') return

      const article = document.querySelector('article')
      if (!(article instanceof HTMLElement)) return

      const rect = article.getBoundingClientRect()
      const articleTop = window.scrollY + rect.top
      const articleHeight = article.scrollHeight
      const viewportHeight = window.innerHeight
      const scrollableDistance = Math.max(
        articleHeight - viewportHeight * 0.35,
        1
      )
      const progress = Math.min(
        1,
        Math.max(
          0,
          (window.scrollY - articleTop + viewportHeight * 0.2) /
            scrollableDistance
        )
      )

      for (const progressEl of this.#progressEls) {
        progressEl.style.setProperty('--toc-progress', `${progress * 100}%`)
        progressEl.setAttribute(
          'aria-valuenow',
          `${Math.round(progress * 100)}`
        )
      }
    }

    #getHeadingLevel = (level: string | undefined) => {
      return level ? parseInt(level, 10) : undefined
    }

    #getElements = (selector: string, fromDocument = true) => {
      return fromDocument
        ? Array.from(document.querySelectorAll(selector))
        : Array.from(this.querySelectorAll(selector))
    }

    #generateHeadingMapToc = (tocLinks: HTMLAnchorElement[]) => {
      for (const link of tocLinks) {
        const { hash } = new URL(link.href)
        const id = decodeURIComponent(hash.replace(/^#/, ''))
        const headingEl = document.getElementById(id)

        if (headingEl) {
          const links = this.#headingMapToc.get(headingEl) ?? []
          links.push(link)
          this.#headingMapToc.set(headingEl, links)
        }
      }
    }

    #getTocHeadingsSelector = (
      minH: number,
      maxH: number,
      baseSelector = ''
    ) => {
      const levelSelectors = []
      for (let i = minH; i <= maxH; i++) {
        baseSelector
          ? levelSelectors.push(`${baseSelector} h${i}`)
          : levelSelectors.push(`article h${i}`)
      }

      return levelSelectors.join(', ')
    }

    #cleanup = () => {
      this.#observer?.disconnect()
      this.#observer = null
      window.removeEventListener('scroll', this.#onScroll)
      window.removeEventListener('resize', this.#onScroll)

      if (this.#scrollFrame !== null) {
        window.cancelAnimationFrame(this.#scrollFrame)
        this.#scrollFrame = null
      }

      this.#headingMapToc.clear()
      this.#headings = []
      this.#progressEls = []
      this.#currentActiveHeading = null
      this.#previousActiveLinks = []
    }
  }

  if (!customElements.get('table-of-contents')) {
    customElements.define('table-of-contents', Toc)
  }
</script>
