---
import Link from '~/components/base/Link.astro'
import { withBasePath } from '~/utils/path'

const pathname = Astro.url.pathname

const destination = pathname.startsWith(withBasePath('/research/'))
  ? { href: '/research/', label: '← Back to research' }
  : pathname.startsWith(withBasePath('/models/')) ||
      pathname.startsWith(withBasePath('/projects/'))
    ? { href: '/models/', label: '← Back to models' }
    : { href: '/', label: '← Back home' }
---

<Link
  class="text-sm op-55! no-underline! transition-opacity hover:op-100!"
  href={withBasePath(destination.href)}
>
  {destination.label}
</Link>
