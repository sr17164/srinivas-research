---
import { withBasePath } from '~/utils/path'

interface Props {
  src: string
  alt: string
  caption: string
  source: string
  sourceHref?: string
}

const { src, alt, caption, source, sourceHref } = Astro.props
---

<figure class="research-figure not-prose">
  <div class="research-figure-frame">
    <img src={withBasePath(src)} {alt} loading="lazy" decoding="async" />
  </div>

  <figcaption>
    <span>{caption}</span>
    <span class="research-figure-source">
      Source:
      {
        sourceHref ? (
          <a href={sourceHref} rel="noreferrer" target="_blank">
            {source}
          </a>
        ) : (
          source
        )
      }
    </span>
  </figcaption>
</figure>

<style is:global>
  .research-figure {
    margin: 2.2rem 0 2.6rem;
  }

  .research-figure-frame {
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--c-text) 14%, transparent);
    border-radius: 0.6rem;
    background: #07111b;
    box-shadow: 0 1.2rem 3rem rgb(0 0 0 / 10%);
  }

  .research-figure img {
    display: block;
    width: 100%;
    height: auto;
    margin: 0;
  }

  .research-figure figcaption {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.75rem 1.5rem;
    align-items: start;
    margin-top: 0.8rem;
    font-size: 0.75rem;
    line-height: 1.55;
    color: inherit;
    opacity: 0.58;
  }

  .research-figure-source {
    text-align: right;
    white-space: nowrap;
  }

  .research-figure-source a {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, currentColor 28%, transparent);
    text-underline-offset: 0.18em;
  }

  @media (max-width: 680px) {
    .research-figure {
      width: calc(100vw - 2rem);
      margin-left: calc(50% - 50vw + 1rem);
    }

    .research-figure figcaption {
      grid-template-columns: 1fr;
    }

    .research-figure-source {
      text-align: left;
      white-space: normal;
    }
  }
</style>
