---
import { readFileSync } from 'node:fs'
import { resolve } from 'node:path'

interface SummaryRow {
  Relationship: string
  Commodity: string
  Lower_Inflation_Beta: number
  High_Inflation_Beta: number
  Regime_Difference: number
  Difference_HAC_PValue: number
}

const projectRoot = resolve(
  process.cwd(),
  'public/projects/commodity-regime-analysis'
)

const csv = readFileSync(
  resolve(projectRoot, 'outputs/primary_relationship_results.csv'),
  'utf8'
).trim()

const [headerLine = '', ...dataLines] = csv.split(/\r?\n/)
const headers = headerLine.split(',')
const rows = dataLines.map((line) => {
  const values = line.split(',')
  const raw = Object.fromEntries(
    headers.map((header, index) => [header, values[index] ?? ''])
  )

  return {
    Relationship: raw.Relationship,
    Commodity: raw.Commodity,
    Lower_Inflation_Beta: Number(raw.Lower_Inflation_Beta),
    High_Inflation_Beta: Number(raw.High_Inflation_Beta),
    Regime_Difference: Number(raw.Regime_Difference),
    Difference_HAC_PValue: Number(raw.Difference_HAC_PValue),
  } satisfies SummaryRow
})

const getVerdict = (pValue: number) => {
  if (pValue < 0.05)
    return {
      label: 'Statistically significant',
      className: 'highlight-verdict-significant',
    }

  return {
    label: 'Not statistically significant',
    className: 'highlight-verdict-muted',
  }
}
---

<section class="commodity-highlights not-prose" aria-label="Key findings">
  {
    rows.map((row) => {
      const verdict = getVerdict(row.Difference_HAC_PValue)

      return (
        <article class="commodity-highlight-card">
          <header>
            <p>{row.Commodity}</p>
            <h3>{row.Relationship}</h3>
          </header>

          <div class="commodity-highlight-metrics">
            <div>
              <span>Lower inflation</span>
              <strong>{row.Lower_Inflation_Beta.toFixed(3)}</strong>
            </div>
            <div>
              <span>High inflation</span>
              <strong>{row.High_Inflation_Beta.toFixed(3)}</strong>
            </div>
            <div>
              <span>Difference</span>
              <strong>{row.Regime_Difference.toFixed(3)}</strong>
            </div>
          </div>

          <footer>
            <span class:list={['highlight-verdict', verdict.className]}>
              {verdict.label}
            </span>
            <span class="highlight-pvalue">
              HAC p = {row.Difference_HAC_PValue.toFixed(3)}
            </span>
          </footer>
        </article>
      )
    })
  }
</section>

<style>
  .commodity-highlights {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin: 1.5rem 0 2rem;
  }

  .commodity-highlight-card {
    padding: 1.1rem 1.15rem 1rem;
    border: 1px solid color-mix(in srgb, currentColor 14%, transparent);
    border-radius: 0.55rem;
    background: color-mix(in srgb, currentColor 3.5%, transparent);
  }

  .commodity-highlight-card header p {
    margin: 0 0 0.4rem;
    font-size: 0.66rem;
    font-weight: 650;
    line-height: 1.2;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.45;
  }

  .commodity-highlight-card h3 {
    margin: 0;
    font-family: Georgia, Cambria, 'Times New Roman', Times, serif;
    font-size: 1.12rem;
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  .commodity-highlight-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
    margin-top: 1rem;
    padding-top: 0.95rem;
    border-top: 1px solid color-mix(in srgb, currentColor 10%, transparent);
  }

  .commodity-highlight-metrics span,
  .highlight-pvalue {
    display: block;
    font-size: 0.66rem;
    font-weight: 650;
    line-height: 1.35;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.45;
  }

  .commodity-highlight-metrics strong {
    display: block;
    margin-top: 0.3rem;
    font-size: 1rem;
    font-weight: 650;
    line-height: 1.3;
  }

  .commodity-highlight-card footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    justify-content: space-between;
    margin-top: 1rem;
    padding-top: 0.9rem;
    border-top: 1px solid color-mix(in srgb, currentColor 10%, transparent);
  }

  .highlight-verdict {
    display: inline-flex;
    gap: 0.4rem;
    align-items: center;
    font-size: 0.74rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .highlight-verdict::before {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: currentColor;
    content: '';
  }

  .highlight-verdict-significant {
    color: #5ccf93;
  }

  .highlight-verdict-muted {
    color: #9baabc;
  }

  @media (max-width: 860px) {
    .commodity-highlights {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .commodity-highlight-metrics {
      grid-template-columns: 1fr;
      gap: 0.65rem;
    }
  }
</style>
