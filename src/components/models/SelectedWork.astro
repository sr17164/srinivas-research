---
interface Item {
  category: string
  title: string
  date: string
  description: string
  result?: string
}

interface Props {
  items: Item[]
}

const { items } = Astro.props
---

<div class="selected-work not-prose">
  {
    items.map((item) => (
      <article class="selected-work-item">
        <div class="selected-work-meta">
          <span>{item.category}</span>
          <time>{item.date}</time>
        </div>

        <h3>{item.title}</h3>
        <p>{item.description}</p>

        {item.result && <strong>{item.result}</strong>}
      </article>
    ))
  }
</div>

<style>
  .selected-work {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin: 1.4rem 0 3rem;
  }

  .selected-work-item {
    padding: 1.25rem 1.3rem 1.35rem;
    border: 1px solid color-mix(in srgb, currentColor 14%, transparent);
    border-radius: 0.5rem;
    background: color-mix(in srgb, currentColor 2.5%, transparent);
  }

  .selected-work-meta {
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    margin-bottom: 0.65rem;

    font-size: 0.64rem;
    font-weight: 650;
    line-height: 1.3;
    letter-spacing: 0.09em;
    text-transform: uppercase;

    opacity: 0.45;
  }

  .selected-work-meta time {
    flex: none;
  }

  .selected-work-item h3 {
    margin: 0;
    font-family: Georgia, Cambria, 'Times New Roman', Times, serif;
    font-size: 1.18rem;
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  .selected-work-item p {
    margin: 0.7rem 0 0;
    font-size: 0.82rem;
    line-height: 1.6;
    opacity: 0.68;
  }

  .selected-work-item strong {
    display: block;
    margin-top: 0.8rem;
    font-size: 0.7rem;
    font-weight: 650;
    line-height: 1.4;
    opacity: 0.62;
  }

  @media (max-width: 680px) {
    .selected-work {
      grid-template-columns: 1fr;
    }
  }
</style>
