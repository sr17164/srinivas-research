---
import { withBasePath } from '~/utils/path'

interface Fact {
  label: string
  value: string
}

interface Action {
  label: string
  href: string
  download?: boolean
}

interface Props {
  category: string
  title: string
  date: string
  description: string
  facts?: Fact[]
  actions?: Action[]
  result?: string
  note?: string
  image?: string
  imageAlt?: string
}

const {
  category,
  title,
  date,
  description,
  facts = [],
  actions = [],
  result,
  note,
  image,
  imageAlt = '',
} = Astro.props
---

<section class="model-project">
  <header class="model-project-header">
    <div>
      <p class="model-project-category">{category}</p>
      <h3>{title}</h3>
    </div>

    <time>{date}</time>
  </header>

  <p class="model-project-description">{description}</p>

  {
    result && (
      <p class="model-project-result">
        <span>Result</span>
        <strong>{result}</strong>
      </p>
    )
  }

  {
    facts.length > 0 && (
      <dl class="model-project-facts">
        {facts.map((fact) => (
          <div>
            <dt>{fact.label}</dt>
            <dd>{fact.value}</dd>
          </div>
        ))}
      </dl>
    )
  }

  <div class="model-project-content">
    <slot />
  </div>

  {
    image && (
      <figure class="model-project-figure">
        <img src={withBasePath(image)} alt={imageAlt} loading="lazy" />
      </figure>
    )
  }

  {
    (actions.length > 0 || note) && (
      <footer class="model-project-footer">
        {actions.length > 0 && (
          <div class="model-project-actions">
            {actions.map((action) => (
              <a
                href={withBasePath(action.href)}
                class="model-project-action"
                download={action.download ? '' : undefined}
              >
                {action.label}
                <span aria-hidden="true">{action.download ? '↓' : '↗'}</span>
              </a>
            ))}
          </div>
        )}

        {note && <p class="model-project-note">{note}</p>}
      </footer>
    )
  }
</section>

<style>
  .model-project {
    box-sizing: border-box;
    width: 100%;
    margin: 1.5rem 0 3rem;
    padding: 1.6rem 1.7rem 1.7rem;
    border: 1px solid color-mix(in srgb, currentColor 15%, transparent);
    border-radius: 0.55rem;
    background: color-mix(in srgb, currentColor 2.5%, transparent);
  }

  .model-project-header {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    justify-content: space-between;
    padding-bottom: 1rem;
    border-bottom: 1px solid color-mix(in srgb, currentColor 11%, transparent);
  }

  .model-project-category {
    margin: 0 0 0.45rem;
    font-size: 0.68rem;
    font-weight: 650;
    line-height: 1.2;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    opacity: 0.48;
  }

  h3 {
    margin: 0;
    font-family: Georgia, Cambria, 'Times New Roman', Times, serif;
    font-size: clamp(1.45rem, 3vw, 1.9rem);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.025em;
  }

  time {
    flex: none;
    padding-top: 0.15rem;
    font-size: 0.72rem;
    line-height: 1.4;
    white-space: nowrap;
    opacity: 0.45;
  }

  .model-project-description {
    max-width: 46rem;
    margin: 1.2rem 0 0;
    font-size: 0.96rem;
    line-height: 1.65;
    opacity: 0.72;
  }

  .model-project-result {
    display: inline-flex;
    gap: 0.7rem;
    align-items: baseline;
    margin: 1.1rem 0 0;
    padding: 0.55rem 0.7rem;
    border: 1px solid color-mix(in srgb, currentColor 13%, transparent);
    border-radius: 0.35rem;
    background: color-mix(in srgb, currentColor 3.5%, transparent);
  }

  .model-project-result span {
    font-size: 0.65rem;
    font-weight: 650;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    opacity: 0.45;
  }

  .model-project-result strong {
    font-size: 0.8rem;
    font-weight: 650;
  }

  .model-project-facts {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin: 1.35rem 0 0;
    border-top: 1px solid color-mix(in srgb, currentColor 10%, transparent);
    border-bottom: 1px solid color-mix(in srgb, currentColor 10%, transparent);
  }

  .model-project-facts div {
    padding: 0.9rem 1rem 0.95rem 0;
  }

  .model-project-facts div + div {
    padding-left: 1rem;
    border-left: 1px solid color-mix(in srgb, currentColor 10%, transparent);
  }

  .model-project-facts dt {
    margin-bottom: 0.32rem;
    font-size: 0.64rem;
    font-weight: 650;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.42;
  }

  .model-project-facts dd {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.45;
    opacity: 0.72;
  }

  .model-project-content {
    margin-top: 1.25rem;
  }

  .model-project-content :global(> :first-child) {
    margin-top: 0;
  }

  .model-project-content :global(> :last-child) {
    margin-bottom: 0;
  }

  .model-project-content :global(p),
  .model-project-content :global(li) {
    font-size: 0.92rem;
    line-height: 1.65;
  }

  .model-project-content :global(ul) {
    margin-top: 0.8rem;
    margin-bottom: 0;
  }

  .model-project-figure {
    overflow: hidden;
    margin: 1.4rem 0 0;
    border: 1px solid color-mix(in srgb, currentColor 11%, transparent);
    border-radius: 0.4rem;
    background: #fff;
  }

  .model-project-figure img {
    display: block;
    width: 100%;
    height: auto;
    margin: 0;
  }

  .model-project-footer {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    justify-content: space-between;
    margin-top: 1.35rem;
    padding-top: 1rem;
    border-top: 1px solid color-mix(in srgb, currentColor 11%, transparent);
  }

  .model-project-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .model-project-action {
    display: inline-flex;
    gap: 0.4rem;
    align-items: center;
    padding: 0.55rem 0.75rem;
    border: 1px solid color-mix(in srgb, currentColor 16%, transparent);
    border-radius: 0.35rem;

    color: inherit;
    font-size: 0.72rem;
    font-weight: 600;
    line-height: 1;
    text-decoration: none;

    opacity: 0.65;
    transition:
      opacity 160ms ease,
      background 160ms ease;
  }

  .model-project-action:hover {
    background: color-mix(in srgb, currentColor 4%, transparent);
    opacity: 1;
  }

  .model-project-note {
    max-width: 28rem;
    margin: 0;
    font-size: 0.68rem;
    line-height: 1.5;
    text-align: right;
    opacity: 0.4;
  }

  @media (max-width: 680px) {
    .model-project {
      padding: 1.3rem 1.25rem 1.4rem;
    }

    .model-project-header {
      display: block;
    }

    time {
      display: block;
      margin-top: 0.7rem;
    }

    .model-project-facts {
      grid-template-columns: 1fr;
    }

    .model-project-facts div {
      padding: 0.8rem 0;
    }

    .model-project-facts div + div {
      padding-left: 0;
      border-top: 1px solid color-mix(in srgb, currentColor 9%, transparent);
      border-left: 0;
    }

    .model-project-footer {
      display: block;
    }

    .model-project-note {
      max-width: none;
      margin-top: 0.9rem;
      text-align: left;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .model-project-action {
      transition: none;
    }
  }
</style>
