---
import Link from '~/components/base/Link.astro'
import { withBasePath } from '~/utils/path'
---

<section
  class="market-hero"
  data-market-hero
  aria-labelledby="market-hero-title"
>
  <canvas class="market-hero-canvas" data-market-hero-canvas aria-hidden="true"
  ></canvas>

  <div class="market-hero-grid" aria-hidden="true"></div>
  <div class="market-hero-glow" aria-hidden="true"></div>

  <div class="market-hero-content">
    <div class="market-hero-kicker">
      <span class="market-hero-status" aria-hidden="true"></span>
      Independent investment research
    </div>

    <h1 id="market-hero-title">
      Research on markets,<br />
      valuation and capital allocation.
    </h1>

    <p class="market-hero-copy">
      Long-form, evidence-driven analysis of commodity markets and macroeconomic
      themes, supported by financial modelling and quantitative research.
    </p>

    <div class="market-hero-actions">
      <Link
        href={withBasePath('/research/')}
        class="market-hero-primary border-b-none!"
      >
        Explore research
        <span aria-hidden="true">→</span>
      </Link>

      <Link
        href={withBasePath('/models/')}
        class="market-hero-secondary border-b-none!"
      >
        View models
        <span aria-hidden="true">↗</span>
      </Link>
    </div>
  </div>

  <div class="market-hero-footer" aria-label="Research areas">
    <span>Commodities</span>
    <span>Macro</span>
    <span>Quantitative research</span>
  </div>
</section>

<script>
  interface Star {
    x: number
    y: number
    z: number
    size: number
    phase: number
    colorIndex: number
  }

  const initialiseMarketHero = () => {
    const canvas = document.querySelector<HTMLCanvasElement>(
      '[data-market-hero-canvas]'
    )
    const hero = canvas?.closest<HTMLElement>('[data-market-hero]')

    if (!canvas || !hero || canvas.dataset.initialised === 'true') return
    canvas.dataset.initialised = 'true'

    const context = canvas.getContext('2d', { alpha: true })
    if (!context) return

    const reduceMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches
    const palette = ['#aef6cf', '#5fe6a0', '#eafff2']

    const makeGlowSprite = (color: string) => {
      const sprite = document.createElement('canvas')
      const spriteContext = sprite.getContext('2d')
      const size = 64

      sprite.width = size
      sprite.height = size

      if (!spriteContext) return sprite

      const gradient = spriteContext.createRadialGradient(
        size / 2,
        size / 2,
        0,
        size / 2,
        size / 2,
        size / 2
      )
      gradient.addColorStop(0, '#ffffff')
      gradient.addColorStop(0.08, color)
      gradient.addColorStop(0.28, `${color}a6`)
      gradient.addColorStop(1, `${color}00`)

      spriteContext.fillStyle = gradient
      spriteContext.fillRect(0, 0, size, size)
      return sprite
    }

    const sprites = palette.map(makeGlowSprite)

    let width = 0
    let height = 0
    let pixelRatio = 1
    let stars: Star[] = []
    let frame = 0
    let previousTime = performance.now()
    let visible = true

    const pointer = {
      x: 0,
      y: 0,
      targetX: 0,
      targetY: 0,
    }

    const makeStar = (randomDepth = true): Star => ({
      x: (Math.random() - 0.5) * 2.2,
      y: (Math.random() - 0.5) * 1.7,
      z: randomDepth ? 0.12 + Math.random() * 0.88 : 1,
      size: 0.45 + Math.pow(Math.random(), 1.8) * 1.6,
      phase: Math.random() * Math.PI * 2,
      colorIndex: Math.floor(Math.random() * palette.length),
    })

    const project = (star: Star, depth = star.z) => {
      const parallaxX = pointer.x * 0.07 * depth
      const parallaxY = pointer.y * 0.05 * depth
      const perspective = 0.58 / Math.max(depth, 0.08)

      return {
        x: width * 0.5 + (star.x + parallaxX) * width * perspective,
        y: height * 0.5 + (star.y + parallaxY) * height * perspective,
      }
    }

    const draw = (time: number, deltaSeconds: number) => {
      context.clearRect(0, 0, width, height)
      context.globalCompositeOperation = 'lighter'

      for (const star of stars) {
        if (!reduceMotion) star.z -= deltaSeconds * 0.035

        if (star.z < 0.08) Object.assign(star, makeStar(false))

        const point = project(star)

        if (
          point.x < -30 ||
          point.x > width + 30 ||
          point.y < -30 ||
          point.y > height + 30
        ) {
          Object.assign(star, makeStar(false))
          continue
        }

        const proximity = 1 - star.z
        const twinkle = 0.72 + Math.sin(time * 0.0014 + star.phase) * 0.28
        const alpha = (0.11 + proximity * 0.55) * twinkle
        const radius = star.size * (0.45 + proximity * 1.55)
        const color = palette[star.colorIndex] ?? palette[0]
        const sprite = sprites[star.colorIndex] ?? sprites[0]

        if (!reduceMotion && proximity > 0.46 && color) {
          const previous = project(star, Math.min(1, star.z + 0.016))
          context.globalAlpha = alpha * 0.25
          context.beginPath()
          context.moveTo(previous.x, previous.y)
          context.lineTo(point.x, point.y)
          context.strokeStyle = color
          context.lineWidth = Math.max(0.25, radius * 0.34)
          context.stroke()
        }

        if (sprite) {
          const drawSize = radius * 7
          context.globalAlpha = alpha
          context.drawImage(
            sprite,
            point.x - drawSize / 2,
            point.y - drawSize / 2,
            drawSize,
            drawSize
          )
        }
      }

      context.globalAlpha = 1
      context.globalCompositeOperation = 'source-over'
    }

    const resize = () => {
      const bounds = hero.getBoundingClientRect()
      width = Math.max(1, Math.round(bounds.width))
      height = Math.max(1, Math.round(bounds.height))
      pixelRatio = Math.min(window.devicePixelRatio || 1, 1.5)

      canvas.width = Math.round(width * pixelRatio)
      canvas.height = Math.round(height * pixelRatio)
      canvas.style.width = `${width}px`
      canvas.style.height = `${height}px`
      context.setTransform(pixelRatio, 0, 0, pixelRatio, 0, 0)

      const targetCount =
        width < 720 ? 190 : Math.min(560, Math.round(width * 0.48))
      stars = Array.from({ length: targetCount }, () => makeStar())

      draw(performance.now(), 0)
    }

    const animate = (time: number) => {
      const deltaSeconds = Math.min(0.05, (time - previousTime) / 1000)
      previousTime = time

      pointer.x += (pointer.targetX - pointer.x) * 0.045
      pointer.y += (pointer.targetY - pointer.y) * 0.045

      if (visible) draw(time, deltaSeconds)
      frame = requestAnimationFrame(animate)
    }

    const onPointerMove = (event: PointerEvent) => {
      const bounds = hero.getBoundingClientRect()
      pointer.targetX = (event.clientX - bounds.left) / bounds.width - 0.5
      pointer.targetY = (event.clientY - bounds.top) / bounds.height - 0.5

      hero.style.setProperty('--pointer-x', `${event.clientX - bounds.left}px`)
      hero.style.setProperty('--pointer-y', `${event.clientY - bounds.top}px`)
    }

    const onPointerLeave = () => {
      pointer.targetX = 0
      pointer.targetY = 0
      hero.style.setProperty('--pointer-x', '72%')
      hero.style.setProperty('--pointer-y', '34%')
    }

    const resizeObserver = new ResizeObserver(resize)
    resizeObserver.observe(hero)

    const visibilityObserver = new IntersectionObserver(
      ([entry]) => {
        visible = Boolean(entry?.isIntersecting)
      },
      { rootMargin: '120px' }
    )
    visibilityObserver.observe(hero)

    hero.addEventListener('pointermove', onPointerMove, { passive: true })
    hero.addEventListener('pointerleave', onPointerLeave)

    resize()
    if (!reduceMotion) frame = requestAnimationFrame(animate)

    const cleanup = () => {
      cancelAnimationFrame(frame)
      resizeObserver.disconnect()
      visibilityObserver.disconnect()
      hero.removeEventListener('pointermove', onPointerMove)
      hero.removeEventListener('pointerleave', onPointerLeave)
      canvas.dataset.initialised = 'false'
    }

    document.addEventListener('astro:before-swap', cleanup, { once: true })
  }

  const marketHeroWindow = window as typeof window & {
    __marketHeroListenerAdded?: boolean
  }

  if (!marketHeroWindow.__marketHeroListenerAdded) {
    marketHeroWindow.__marketHeroListenerAdded = true
    document.addEventListener('astro:page-load', initialiseMarketHero)
  }

  initialiseMarketHero()
</script>

<style>
  .market-hero {
    --pointer-x: 72%;
    --pointer-y: 34%;

    isolation: isolate;
    position: relative;
    overflow: hidden;

    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);

    display: flex;
    flex-direction: column;
    justify-content: space-between;

    min-height: clamp(34rem, 72vh, 45rem);
    margin-top: 0;
    margin-bottom: clamp(4rem, 8vw, 7rem);
    padding: clamp(2rem, 4vw, 3.25rem) clamp(2rem, 5.5vw, 4.5rem);

    border: 1px solid rgb(174 246 207 / 16%);
    border-radius: 0;

    background:
      radial-gradient(
        circle at 82% 18%,
        rgb(95 230 160 / 11%),
        transparent 32%
      ),
      radial-gradient(
        circle at 18% 95%,
        rgb(174 246 207 / 7%),
        transparent 36%
      ),
      linear-gradient(145deg, #070d18 0%, #07111b 47%, #05090f 100%);
    color: #f2fff7;
    box-shadow:
      0 1.5rem 5rem rgb(0 0 0 / 12%),
      inset 0 1px rgb(255 255 255 / 4%);
  }

  .market-hero::before {
    position: absolute;
    z-index: -1;
    inset: 0;

    background: linear-gradient(
      90deg,
      rgb(7 13 24 / 96%) 0%,
      rgb(7 13 24 / 78%) 45%,
      rgb(7 13 24 / 16%) 100%
    );
    content: '';
    pointer-events: none;
  }

  .market-hero-canvas,
  .market-hero-grid,
  .market-hero-glow {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .market-hero-canvas {
    z-index: -3;
    opacity: 0;
    animation: market-hero-appear 1.3s 180ms ease forwards;
  }

  .market-hero-grid {
    z-index: -2;

    background-image:
      linear-gradient(rgb(174 246 207 / 3.5%) 1px, transparent 1px),
      linear-gradient(90deg, rgb(174 246 207 / 3.5%) 1px, transparent 1px);
    background-position: center;
    background-size: 4.5rem 4.5rem;

    -webkit-mask-image: linear-gradient(
      to right,
      transparent 4%,
      black 60%,
      black 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 4%,
      black 60%,
      black 100%
    );
    opacity: 0.38;
    transform: perspective(34rem) rotateX(63deg) scale(1.35) translateY(30%);
    transform-origin: bottom center;
  }

  .market-hero-glow {
    z-index: -1;

    background: radial-gradient(
      circle 16rem at var(--pointer-x) var(--pointer-y),
      rgb(95 230 160 / 9%),
      transparent 72%
    );
    transition: background-position 120ms linear;
  }

  .market-hero-content {
    position: relative;
    z-index: 1;
    width: min(100%, 57rem);
    margin-inline: auto;
    padding-top: clamp(0.25rem, 2vw, 1.5rem);
  }

  .market-hero-kicker {
    display: flex;
    gap: 0.7rem;
    align-items: center;

    margin: 0;

    color: rgb(234 255 242 / 68%);
    font-size: 0.7rem;
    font-weight: 650;
    line-height: 1;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .market-hero-status {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: #5fe6a0;
    box-shadow: 0 0 0.8rem rgb(95 230 160 / 80%);
  }

  .market-hero h1 {
    max-width: 59rem;
    margin: 1.5rem 0 1.8rem;

    color: #f4fff8;
    font-family: Georgia, Cambria, 'Times New Roman', Times, serif;
    font-size: clamp(3rem, 7vw, 6.2rem);
    font-weight: 500;
    line-height: 0.96;
    letter-spacing: -0.06em;

    text-wrap: balance;
    text-shadow: 0 0.1rem 2rem rgb(0 0 0 / 20%);
  }

  .market-hero-copy {
    max-width: 39rem;
    margin: 0;

    color: rgb(234 255 242 / 66%);
    font-size: clamp(1rem, 1.8vw, 1.22rem);
    line-height: 1.65;
    text-wrap: pretty;
  }

  .market-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 1.4rem;
    align-items: center;
    margin-top: 2.35rem;
  }

  .market-hero-primary,
  .market-hero-secondary {
    display: inline-flex;
    gap: 0.75rem;
    align-items: center;
    justify-content: center;

    min-height: 2.8rem;
    padding: 0.75rem 1rem;

    font-size: 0.83rem;
    font-weight: 650;
    text-decoration: none;

    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease,
      opacity 160ms ease;
  }

  .market-hero-primary {
    background: #eafff2;
    color: #07111b;
    opacity: 1;
  }

  .market-hero-primary:hover {
    transform: translateY(-0.1rem);
    background: #ffffff;
  }

  .market-hero-secondary {
    border: 1px solid rgb(234 255 242 / 22%);
    color: #eafff2;
    opacity: 0.72;
  }

  .market-hero-secondary:hover {
    transform: translateY(-0.1rem);
    border-color: rgb(234 255 242 / 48%);
    background: rgb(234 255 242 / 5%);
    opacity: 1;
  }

  .market-hero-footer {
    position: relative;
    z-index: 1;

    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem 1.5rem;
    align-items: center;

    width: min(100%, 57rem);
    margin: 3rem auto 0;
    padding-top: 1.1rem;
    border-top: 1px solid rgb(234 255 242 / 11%);

    color: rgb(234 255 242 / 36%);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .market-hero-footer span + span::before {
    margin-right: 1.5rem;
    content: '·';
  }

  @keyframes market-hero-appear {
    to {
      opacity: 0.88;
    }
  }

  @media (max-width: 720px) {
    .market-hero {
      min-height: 38rem;
      margin-top: 0;
      padding: 2rem 1.4rem;
    }

    .market-hero::before {
      background: linear-gradient(
        180deg,
        rgb(7 13 24 / 82%) 0%,
        rgb(7 13 24 / 94%) 65%,
        rgb(7 13 24 / 98%) 100%
      );
    }

    .market-hero-content {
      padding-top: 0.5rem;
    }

    .market-hero h1 {
      font-size: clamp(3rem, 14vw, 4.5rem);
      line-height: 0.98;
    }

    .market-hero-copy {
      font-size: 1rem;
    }

    .market-hero-actions {
      align-items: stretch;
    }

    .market-hero-primary,
    .market-hero-secondary {
      flex: 1 1 12rem;
    }

    .market-hero-footer {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .market-hero-canvas {
      opacity: 0.6;
      animation: none;
    }

    .market-hero-primary,
    .market-hero-secondary {
      transition: none;
    }
  }
</style>
