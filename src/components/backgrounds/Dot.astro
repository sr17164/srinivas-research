<bg-dot
  class="z--1 fixed top-0 bottom-0 left-0 right-0 pointer-events-none print:hidden"
  aria-hidden="true"
>
  <canvas></canvas>
</bg-dot>

<script>
  interface DotPoint {
    x: number
    y: number
    phase: number
    opacity: number
  }

  class BgDotElement extends HTMLElement {
    private canvas: HTMLCanvasElement | null = null
    private context: CanvasRenderingContext2D | null = null
    private points: DotPoint[] = []
    private frame = 0
    private width = 0
    private height = 0
    private lastDraw = 0
    private reduceMotion = false

    connectedCallback() {
      this.canvas = this.querySelector('canvas')
      this.context = this.canvas?.getContext('2d') ?? null
      this.reduceMotion = window.matchMedia(
        '(prefers-reduced-motion: reduce)'
      ).matches

      if (!this.canvas || !this.context) return

      window.addEventListener('resize', this.resize, { passive: true })
      document.addEventListener('astro:before-swap', this.cleanup, {
        once: true,
      })

      this.resize()
      this.draw(performance.now())
      if (!this.reduceMotion) this.frame = requestAnimationFrame(this.tick)
    }

    disconnectedCallback() {
      this.cleanup()
    }

    private resize = () => {
      if (!this.canvas || !this.context) return

      this.width = Math.max(1, window.innerWidth)
      this.height = Math.max(1, window.innerHeight)
      const pixelRatio = Math.min(window.devicePixelRatio || 1, 1.5)

      this.canvas.width = Math.round(this.width * pixelRatio)
      this.canvas.height = Math.round(this.height * pixelRatio)
      this.canvas.style.width = `${this.width}px`
      this.canvas.style.height = `${this.height}px`
      this.context.setTransform(pixelRatio, 0, 0, pixelRatio, 0, 0)

      const spacing = this.width < 720 ? 24 : 18
      this.points = []

      for (let x = -spacing; x <= this.width + spacing; x += spacing) {
        for (let y = -spacing; y <= this.height + spacing; y += spacing) {
          this.points.push({
            x,
            y,
            phase: Math.random() * Math.PI * 2,
            opacity: 0.24 + Math.random() * 0.42,
          })
        }
      }
    }

    private draw = (time: number) => {
      if (!this.context) return

      this.context.clearRect(0, 0, this.width, this.height)
      const isDark = document.documentElement.classList.contains('dark')
      const channel = isDark ? 82 : 155
      const seconds = time / 1000

      for (const point of this.points) {
        const angle =
          Math.sin(point.x * 0.009 + seconds * 0.26 + point.phase) +
          Math.cos(point.y * 0.008 - seconds * 0.19)
        const distance =
          2.5 + (Math.sin(seconds * 0.32 + point.phase) + 1) * 2.4
        const x = point.x + Math.cos(angle) * distance
        const y = point.y + Math.sin(angle) * distance

        this.context.fillStyle = `rgba(${channel}, ${channel}, ${channel}, ${point.opacity})`
        this.context.fillRect(x, y, 1.4, 1.4)
      }
    }

    private tick = (time: number) => {
      if (time - this.lastDraw >= 100) {
        this.lastDraw = time
        this.draw(time)
      }
      this.frame = requestAnimationFrame(this.tick)
    }

    private cleanup = () => {
      cancelAnimationFrame(this.frame)
      window.removeEventListener('resize', this.resize)
    }
  }

  if (!customElements.get('bg-dot')) {
    customElements.define('bg-dot', BgDotElement)
  }
</script>

<style>
  bg-dot,
  bg-dot canvas {
    width: 100%;
    height: 100%;
  }

  bg-dot canvas {
    display: block;
  }
</style>
