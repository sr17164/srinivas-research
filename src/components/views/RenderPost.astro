---
import { render } from 'astro:content'

import BaseLayout from '~/layouts/BaseLayout.astro'
import StandardLayout from '~/layouts/StandardLayout.astro'
import PostMeta from '~/components/base/PostMeta.astro'
import ResearchFactsheet from '~/components/base/ResearchFactsheet.astro'
import Warning from '~/components/base/Warning.astro'
import DesktopAside from '~/components/base/DesktopAside.astro'
import MobileControl from '~/components/base/MobileControl.astro'
import PostCover from '~/components/base/PostCover.astro'
import ImageViewer from '~/components/widgets/ImageViewer.astro'

import { getMinutesRead } from '~/utils/data'
import { FEATURES } from '~/config'

import type { CollectionEntry } from 'astro:content'

interface Props {
  post: CollectionEntry<'blog'>
  isCommentable?: boolean
  pageToc?: boolean
}

const { post, pageToc = true } = Astro.props

const { toc, search } = FEATURES

const { data: frontmatter } = post
const { Content, headings, remarkPluginFrontmatter } = await render(post)

const title = frontmatter.title
const description = frontmatter.description
const ogImage = frontmatter.ogImage
const pubDate = frontmatter.pubDate.toISOString()

const lastModDate =
  frontmatter.lastModDate instanceof Date
    ? frontmatter.lastModDate.toISOString()
    : undefined

const bgType = frontmatter.bgType
const subtitle = frontmatter.subtitle

const minutesRead = getMinutesRead(
  frontmatter.minutesRead,
  remarkPluginFrontmatter.minutesRead as number
)

const tags = frontmatter.tags
const reportType = frontmatter.reportType
const assetClass = frontmatter.assetClass
const sector = frontmatter.sector
const isDraft = frontmatter.draft
const cover = frontmatter.cover
const coverAlt = frontmatter.coverAlt

const investmentView = frontmatter.investmentView
const timeHorizon = frontmatter.timeHorizon
const outcome = frontmatter.outcome

const tocEnabled = Array.isArray(toc) && toc[0] && frontmatter.toc && pageToc

const haveHeadings = tocEnabled && headings.length > 0

const isSearchable =
  Array.isArray(search) &&
  search[0] &&
  search[1].includes.includes('blog') &&
  frontmatter.search

const searchFilter =
  isSearchable && search[1].filter ? 'collection:blog' : undefined

const draftWarning = `
  This is a draft article and will not be published in production.
  Set the article's <code>draft</code> property to <code>false</code>
  or remove it to publish the article.
`
---

<BaseLayout {title} {description} {ogImage} {pubDate} {lastModDate} {bgType}>
  <StandardLayout
    {title}
    subtitle={subtitle ?? description}
    {isSearchable}
    {searchFilter}
  >
    <Fragment slot="head">
      <PostMeta
        {pubDate}
        {lastModDate}
        {minutesRead}
        {tags}
        {reportType}
        {assetClass}
        {sector}
      />

      <ResearchFactsheet {investmentView} {timeHorizon} {outcome} />
    </Fragment>

    <Fragment slot="article">
      {isDraft && <Warning html={draftWarning} />}

      {
        haveHeadings && (
          <>
            <DesktopAside {headings} />
            <MobileControl {headings} />
          </>
        )
      }

      {cover && <PostCover {cover} {coverAlt} />}

      <hr class="research-divider" />

      <Content />
    </Fragment>
  </StandardLayout>

  <ImageViewer
    selector="article"
    options={{
      title: 0,
      navbar: 0,
    }}
  />
</BaseLayout>
