---
interface Props {
  investmentView?: 'Bullish' | 'Bearish' | 'Neutral'
  timeHorizon?: string
  outcome?: 'Successful' | 'Unsuccessful' | 'Mixed' | 'Open'
  drivers?: string[]
}

const { investmentView, timeHorizon, outcome, drivers = [] } = Astro.props

const hasFactsheet =
  Boolean(investmentView) ||
  Boolean(timeHorizon) ||
  Boolean(outcome) ||
  drivers.length > 0
---

{
  hasFactsheet && (
    <section class="research-factsheet" aria-label="Research summary">
      <div class="research-factsheet-grid">
        {investmentView && (
          <div class="research-fact">
            <span class="research-fact-label">Investment view</span>
            <span
              class:list={[
                'research-view',
                `research-view-${investmentView.toLowerCase()}`,
              ]}
            >
              {investmentView}
            </span>
          </div>
        )}

        {timeHorizon && (
          <div class="research-fact">
            <span class="research-fact-label">Time horizon</span>
            <span class="research-fact-value">{timeHorizon}</span>
          </div>
        )}

        {outcome && (
          <div class="research-fact">
            <span class="research-fact-label">Outcome</span>
            <span
              class:list={[
                'research-outcome',
                `research-outcome-${outcome.toLowerCase()}`,
              ]}
            >
              {outcome}
            </span>
          </div>
        )}
      </div>

      {drivers.length > 0 && (
        <div class="research-drivers">
          <span class="research-fact-label">Primary drivers</span>

          <ul>
            {drivers.map((driver) => (
              <li>{driver}</li>
            ))}
          </ul>
        </div>
      )}
    </section>
  )
}

<style>
  .research-factsheet {
    margin: 2rem 0 3rem;
    padding: 1.5rem 0;
    border-top: 1px solid color-mix(in srgb, var(--c-text) 18%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--c-text) 18%, transparent);
  }

  .research-factsheet-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    gap: 1.5rem;
  }

  .research-fact {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .research-fact-label {
    display: block;

    font-size: 0.68rem;
    font-weight: 650;
    line-height: 1.2;
    letter-spacing: 0.1em;
    text-transform: uppercase;

    opacity: 0.48;
  }

  .research-fact-value,
  .research-view,
  .research-outcome {
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.35;
  }

  .research-view {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 0.45rem;
  }

  .research-view::before {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: currentColor;
    content: '';
  }

  .research-view-bullish {
    color: #1f7a4f;
  }

  .research-view-bearish {
    color: #a33a3a;
  }

  .research-view-neutral {
    color: #777;
  }

  .research-outcome {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 0.45rem;
  }

  .research-outcome::before {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: currentColor;
    content: '';
  }

  .research-outcome-successful {
    color: #1f7a4f;
  }

  .research-outcome-unsuccessful {
    color: #a33a3a;
  }

  .research-outcome-mixed {
    color: #82764f;
  }

  .research-outcome-open {
    color: #4f6f91;
  }

  :global(html.dark) .research-view-bullish {
    color: #67c995;
  }

  :global(html.dark) .research-view-bearish {
    color: #e88383;
  }

  :global(html.dark) .research-view-neutral {
    color: #aaa;
  }

  :global(html.dark) .research-outcome-successful {
    color: #67c995;
  }

  :global(html.dark) .research-outcome-unsuccessful {
    color: #e88383;
  }

  :global(html.dark) .research-outcome-mixed {
    color: #c7b878;
  }

  :global(html.dark) .research-outcome-open {
    color: #8fb7de;
  }

  .research-drivers {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--c-text) 10%, transparent);
  }

  .research-drivers ul {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.55rem 1.5rem;

    margin: 0.8rem 0 0;
    padding: 0;

    list-style: none;
  }

  .research-drivers li {
    position: relative;
    margin: 0;
    padding-left: 1rem;

    font-size: 0.9rem;
    line-height: 1.5;
  }

  .research-drivers li::before {
    position: absolute;
    top: 0.65em;
    left: 0;

    width: 0.3rem;
    height: 0.3rem;
    border-radius: 999px;

    background: currentColor;
    content: '';
    opacity: 0.45;
  }

  @media (max-width: 640px) {
    .research-factsheet {
      margin-top: 1.75rem;
      margin-bottom: 2.5rem;
    }

    .research-factsheet-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .research-drivers ul {
      grid-template-columns: 1fr;
    }
  }
</style>
